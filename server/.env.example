# Cogitator Server Environment Variables
#
# Copy this file to .env and adjust values as needed.
# File-based config (cogitator.yaml) takes precedence where set.

# --- Server ---
# COGITATOR_SERVER_PORT=8484
# COGITATOR_SERVER_HOST=0.0.0.0

# --- Workspace ---
# COGITATOR_WORKSPACE_PATH=./data

# --- Model ---
# COGITATOR_MODEL_PROVIDER=openai
# COGITATOR_MODEL=gpt-4o

# --- Memory Retrieval ---
# Maximum estimated tokens of retrieved context injected into the system prompt.
# Higher values surface more memories but consume more of the LLM context window.
# COGITATOR_RETRIEVAL_TOKEN_BUDGET=2000

# Cosine similarity floor. Candidates below this score are dropped.
# Lower values include weaker matches; higher values are stricter.
# COGITATOR_RETRIEVAL_MIN_SIMILARITY=0.3

# Score multiplier for preference and fact nodes. Gives stable knowledge
# a slight edge over other types in retrieval ranking.
# COGITATOR_RETRIEVAL_TYPE_BOOST=1.1

# Bump this integer to trigger re-enrichment of all memory nodes on next startup.
# The server compares this to the stored version and re-enriches when higher.
# COGITATOR_ENRICHMENT_VERSION=1

# Cosine similarity threshold for deduplicating near-identical memories.
# Higher values are stricter (fewer merges). Range: 0.0-1.0.
# COGITATOR_DEDUP_SIMILARITY_THRESHOLD=0.90

# --- Embedding ---
# COGITATOR_MEMORY_EMBEDDING_MODEL=text-embedding-3-small

# --- Security ---
# COGITATOR_SECURITY_SANDBOX=host
# COGITATOR_SECURITY_MAX_OUTPUT=65536
