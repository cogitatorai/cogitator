# Server
COGITATOR_SERVER_PORT=8484
COGITATOR_SERVER_HOST=0.0.0.0
# Use a full absolute path (Docker Compose does not expand variables like ${HOME} or ~)
COGITATOR_WORKSPACE_PATH=/Users/me/.cogitator

# Persist auth (to generate one, use: openssl rand -hex 32)
COGITATOR_JWT_SECRET=

# Dashboard
# Path to the dashboard dist/ directory (auto-detected in dev; set for custom layouts)
# COGITATOR_DASHBOARD_DIR=

# Security
COGITATOR_SECURITY_SANDBOX=host
# Maximum output size (in bytes) for sandboxed command execution (defaults to 64KB)
COGITATOR_SECURITY_MAX_OUTPUT=

# Connectors and login (optional, per-connector OAuth credentials)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
